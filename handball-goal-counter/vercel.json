{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300,
      "memory": 3008
    }
  },
  "env": {
    "PYTHON_VERSION": "3.11",
    "ENABLE_SUPERPOWERS": "1"
  },
  "buildCommand": "npm install && pip install --upgrade pip && pip install -r requirements.txt",
  "installCommand": "pip3 install --user -r requirements.txt"
}
